{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkLane",
  "version": "0.1.0",
  "identifier": "com.eliostruyf.linklane",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "picker",
        "title": "LinkLane",
        "width": 250,
        "height": 320,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "minWidth": 250,
        "maxWidth": 250,
        "minHeight": 120
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["http", "https"]
      }
    }
  }
}
